{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "postbuild": "node -e \"const fs = require('fs'); const path = require('path'); const deleteTxt = (dir) => { if (!fs.existsSync(dir)) return; fs.readdirSync(dir).forEach(file => { const p = path.join(dir, file); if (fs.statSync(p).isDirectory()) { deleteTxt(p); } else if (p.endsWith('.txt')) { fs.unlinkSync(p); } }); }; deleteTxt('out'); fs.writeFileSync('out/.nojekyll', '');\"",
    "start": "next start",
    "lint": "next lint"
  },
